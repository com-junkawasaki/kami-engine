;; kami-mangaka-expression-clj — work-agnostic manga EXPRESSION patterns.
;;
;; 「キャラクターごとに、表情・姿勢・吹き出しの形・文字の薄さ・大きさ・背景トーンを
;;  変える」漫画的表現を DATA (resources/mangaka_expression_patterns.edn) から決める
;; 純粋レイヤ。archetype ← register ← expression-cue ← intensity を merge して 1 行分の
;; スタイルを解決し (resolve-style)、storyboard に当てる (analyze-line/panel/page)。
;; 出典は HUNTER×HUNTER 王位継承戦編のコマ観察 (ADR-2607012100)。
;;
;; 純 clj/cljc — babashka-safe, GPU/AWT なし。SEMANTIC タグだけを吐き、見た目への写像は
;; renderer 側 (kami-mangaka-text-clj の hiccup+CSS / kami-mangaka-page-clj の Java2D)。
;; langgraph の ai.gftd.mangaka.analyzeExpression がこの analyze-page を呼ぶ。
;; Sibling of kami-mangaka-text-clj / -page-clj / -scene-clj。ADR-2606282100/101。
{:paths ["src" "resources"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}}}
