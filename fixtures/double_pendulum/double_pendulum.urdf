<?xml version="1.0" encoding="utf-8"?>
<!--
  Double pendulum reference URDF for e7m-sim R1.1+ (ADR-2605261800).
  2-link revolute serial chain with all rotation about world Y (planar XZ motion).

  Topology:
    world  -[revolute_y]-  link1  -[revolute_y]-  link2

  Reference values (textbook double pendulum, e.g. Tedrake's underactuated):
    link1: mass 1.0 kg, length 1.0 m, com at half length (0.5 m), I_yy at com = m*l^2/12
    link2: mass 1.0 kg, length 1.0 m, com at half length (0.5 m), I_yy at com = m*l^2/12
-->
<robot name="double_pendulum">

  <link name="world"/>

  <link name="link1">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0" iyy="0.08333333" izz="0.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="shoulder" type="revolute">
    <parent link="world"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="100.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="link2">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0" iyy="0.08333333" izz="0.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry>
        <cylinder length="1.0" radius="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="elbow" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 -1.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="100.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
