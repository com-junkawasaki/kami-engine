<?xml version="1.0" encoding="utf-8"?>
<!--
  3-link planar revolute arm — reference URDF for the kami-genesis PlanarChain
  topology (ADR-2605261800 §D10.1, N>=3 serial revolute generalization of the
  cartpole / double-pendulum solvers).

  Topology:
    base -[j1 rev +y]- l1 -[j2 rev +y]- l2 -[j3 rev +y]- l3

  Each link ~0.30 m, masses 0.4 / 0.3 / 0.2 kg, all revolute joints about +y
  in the x-z plane. detect_topology() recognizes this as a serial revolute
  chain of 3 joints and builds a PlanarChainConfig (RNEA bias + CRBA mass
  matrix + LDL^T solve, semi-implicit Euler).
-->
<robot name="arm3">

  <link name="base"/>

  <link name="l1">
    <inertial>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.003" iyy="0.003" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base"/>
    <child link="l1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="l2">
    <inertial>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j2" type="revolute">
    <parent link="l1"/>
    <child link="l2"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="l3">
    <inertial>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j3" type="revolute">
    <parent link="l2"/>
    <child link="l3"/>
    <origin xyz="0 0 -0.30" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="10.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
